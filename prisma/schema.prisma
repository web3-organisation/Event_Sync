generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

// ─────────────────────────────────────────────
// ADMINS
// ─────────────────────────────────────────────
model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  // Asso: admin_question (admins <-> questions)
  adminQuestions AdminQuestion[]

  // Asso: admin_session (admins <-> sessions)
  adminSessions AdminSession[]

  // Asso: admin_speakers (admins <-> speakers)
  adminSpeakers AdminSpeaker[]

  // Asso 7: admins <-> events
  adminEvents AdminEvent[]

  // Asso: admin_room (admins <-> rooms)
  adminRooms AdminRoom[]

  @@map("admins")
}

// ─────────────────────────────────────────────
// EVENTS
// ─────────────────────────────────────────────
model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  location    String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Asso_1: events -> rooms
  rooms Room[]

  // Asso_2: events -> sessions
  sessions Session[]

  // Asso 7: admins <-> events
  adminEvents AdminEvent[]

  @@map("events")
}

// ─────────────────────────────────────────────
// ROOMS
// ─────────────────────────────────────────────
model Room {
  id      String @id @default(uuid())
  name    String

  // Asso_1: rooms -> events (0,n event_id)
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id])

  // Asso_3: rooms -> sessions (0,n room_id)
  sessions Session[]

  // admin_room: admins <-> rooms
  adminRooms AdminRoom[]

  @@map("rooms")
}

// ─────────────────────────────────────────────
// SESSIONS
// ─────────────────────────────────────────────
model Session {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  capacity    Int?

  // Asso_2: sessions -> events
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id])

  // Asso_3: sessions -> rooms
  roomId String @map("room_id")
  room   Room   @relation(fields: [roomId], references: [id])

  // session_speakers: sessions <-> speakers (0,n session_id)
  sessionSpeakers SessionSpeaker[]

  // admin_session: admins <-> sessions
  adminSessions AdminSession[]

  // questions -> sessions
  questions Question[]

  @@map("sessions")
}

// ─────────────────────────────────────────────
// SPEAKERS
// ─────────────────────────────────────────────
model Speaker {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name")
  photoUrl  String?  @map("photo_url")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")

  // Asso_4: speakers -> speaker_links (0,n speaker_id)
  speakerLinks SpeakerLink[]

  // session_speakers: speakers <-> sessions (0,n speaker_id)
  sessionSpeakers SessionSpeaker[]

  // admin_speakers: admins <-> speakers
  adminSpeakers AdminSpeaker[]

  @@map("speakers")
}

// ─────────────────────────────────────────────
// SPEAKER LINKS
// ─────────────────────────────────────────────
model SpeakerLink {
  id    String @id @default(uuid())
  label String
  url   String

  // Asso_4: speaker_links -> speakers
  speakerId String  @map("speaker_id")
  speaker   Speaker @relation(fields: [speakerId], references: [id])

  @@map("speaker_links")
}

// ─────────────────────────────────────────────
// QUESTIONS
// ─────────────────────────────────────────────
model Question {
  id         String   @id @default(uuid())
  content    String
  authorName String?  @map("author_name")
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  // questions -> sessions
  sessionId String  @map("session_id")
  session   Session @relation(fields: [sessionId], references: [id])

  // admin_question: admins <-> questions
  adminQuestions AdminQuestion[]

  @@map("questions")
}

// ─────────────────────────────────────────────
// TABLES D'ASSOCIATION (ovales Looping)
// ─────────────────────────────────────────────

// admin_question — admins <-> questions
model AdminQuestion {
  adminId    String @map("id_admins")
  questionId String @map("id_questions")

  admin    Admin    @relation(fields: [adminId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@id([adminId, questionId])
  @@map("admin_question")
}

// admin_session — admins <-> sessions
model AdminSession {
  adminId   String @map("id_admin")
  sessionId String @map("id_sessions")

  admin   Admin   @relation(fields: [adminId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@id([adminId, sessionId])
  @@map("admin_session")
}

// admin_speakers — admins <-> speakers
model AdminSpeaker {
  adminId   String @map("id_admin")
  speakerId String @map("id_speaker")

  admin   Admin   @relation(fields: [adminId], references: [id])
  speaker Speaker @relation(fields: [speakerId], references: [id])

  @@id([adminId, speakerId])
  @@map("admin_speakers")
}

// admin_room — admins <-> rooms
model AdminRoom {
  adminId String @map("id_admin")
  roomId  String @map("id_rooms")

  admin Admin @relation(fields: [adminId], references: [id])
  room  Room  @relation(fields: [roomId], references: [id])

  @@id([adminId, roomId])
  @@map("admin_room")
}

// Asso 7 — admins <-> events
model AdminEvent {
  adminId String @map("id_admins")
  eventId String @map("id_events")

  admin Admin @relation(fields: [adminId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@id([adminId, eventId])
  @@map("admin_event")
}

// session_speakers — sessions <-> speakers
model SessionSpeaker {
  sessionId String @map("session_id")
  speakerId String @map("speaker_id")

  session Session @relation(fields: [sessionId], references: [id])
  speaker Speaker @relation(fields: [speakerId], references: [id])

  @@id([sessionId, speakerId])
  @@map("session_speakers")
}
